---
import Wireframe from '../layouts/Wireframe.astro';
---
<Wireframe title="Location Detail">
  <p style="font-size: 0.8rem; opacity: 0.6;">User who tapped a pin on the Map.</p>

  <p style="margin: 0.25rem 0 0.75rem; font-size: 0.9rem; opacity: 0.7;">📍 Santa Barbara, CA — NEON Site</p>

  <wired-input placeholder="Search species at this location..." style="width: 100%; display: block; margin-bottom: 1rem;"></wired-input>

  <!-- Species list -->
  <div style="display: flex; flex-direction: column; gap: 0.5rem;">

    <a href="/species-detail" style="text-decoration: none; color: inherit;">
      <wired-card elevation="1" style="padding: 0.75rem; display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
        <div style="width: 48px; height: 48px; border: 1px dashed #222; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0;">🐦</div>
        <div>
          <div style="font-weight: bold;">California Towhee</div>
          <div style="font-size: 0.8rem; opacity: 0.6;">Melozone crissalis</div>
        </div>
      </wired-card>
    </a>

    <a href="/species-detail" style="text-decoration: none; color: inherit;">
      <wired-card elevation="1" style="padding: 0.75rem; display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
        <div style="width: 48px; height: 48px; border: 1px dashed #222; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0;">🐦</div>
        <div>
          <div style="font-weight: bold;">House Finch</div>
          <div style="font-size: 0.8rem; opacity: 0.6;">Haemorhous mexicanus</div>
        </div>
      </wired-card>
    </a>

    <a href="/species-detail" style="text-decoration: none; color: inherit;">
      <wired-card elevation="1" style="padding: 0.75rem; display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
        <div style="width: 48px; height: 48px; border: 1px dashed #222; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0;">🐦</div>
        <div>
          <div style="font-weight: bold;">Western Scrub-Jay</div>
          <div style="font-size: 0.8rem; opacity: 0.6;">Aphelocoma californica</div>
        </div>
      </wired-card>
    </a>

  </div>

  <!-- Empty state -->
  <wired-card elevation="1" style="padding: 1rem; margin-top: 1rem; display: none; text-align: center; opacity: 0.6;">
    <p>No results for that species at this location.</p>
  </wired-card>

  <div class="scenario-note">
    <strong>Actions:</strong>
    <ul>
      <li>Search → filters list; shows "no results" if nothing found</li>
      <li>Tap a species → <a href="/species-detail">Species Detail</a></li>
    </ul>
  </div>
</Wireframe>
