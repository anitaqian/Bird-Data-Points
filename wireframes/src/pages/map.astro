---
import Wireframe from '../layouts/Wireframe.astro';
---
<Wireframe title="Map">
  <p style="font-size: 0.8rem; opacity: 0.6;">User who tapped Explore Map from Home.</p>

  <wired-input placeholder="Search for a location..." style="width: 100%; margin-bottom: 1rem; display: block;"></wired-input>

  <wired-card elevation="2" style="padding: 0; margin: 0.5rem 0; display: block; position: relative; height: 320px; overflow: hidden;">
    <!-- Map placeholder -->
    <div style="
      width: 100%;
      height: 100%;
      background: repeating-linear-gradient(
        45deg,
        #e8e0c8,
        #e8e0c8 10px,
        #f0e8d0 10px,
        #f0e8d0 20px
      );
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 0.5rem;
    ">
      <span style="font-size: 0.8rem; opacity: 0.5;">[ interactive map ]</span>

      <!-- Simulated pins linking to Location Detail -->
      <div style="display: flex; gap: 2rem; margin-top: 1rem; flex-wrap: wrap; justify-content: center;">
        <a href="/location-detail" title="NEON Site — Great Smoky Mountains">
          <div style="text-align: center; cursor: pointer;">
            <div style="font-size: 1.5rem;">📍</div>
            <div style="font-size: 0.65rem; background: #fdf8ec; padding: 2px 4px; border: 1px dashed #222; border-radius: 2px;">Great Smoky Mtns</div>
          </div>
        </a>
        <a href="/location-detail" title="NEON Site — Jornada">
          <div style="text-align: center; cursor: pointer;">
            <div style="font-size: 1.5rem;">📍</div>
            <div style="font-size: 0.65rem; background: #fdf8ec; padding: 2px 4px; border: 1px dashed #222; border-radius: 2px;">Jornada, NM</div>
          </div>
        </a>
        <a href="/location-detail" title="NEON Site — Santa Barbara">
          <div style="text-align: center; cursor: pointer;">
            <div style="font-size: 1.5rem;">📍</div>
            <div style="font-size: 0.65rem; background: #fdf8ec; padding: 2px 4px; border: 1px dashed #222; border-radius: 2px;">Santa Barbara, CA</div>
          </div>
        </a>
      </div>
    </div>
  </wired-card>

  <p style="font-size: 0.8rem; opacity: 0.6; margin-top: 0.5rem;">Tap a 📍 pin to see bird data for that location.</p>

  <div class="scenario-note">
    <strong>Actions:</strong>
    <ul>
      <li>Tap a pin → <a href="/location-detail">Location Detail</a></li>
      <li>Search → map pans to location; pin highlighted if data exists</li>
    </ul>
  </div>
</Wireframe>
